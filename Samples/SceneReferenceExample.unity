  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '<b>Scene Registry</b>


    Scene Registry is a Unity package that solves
    a common problem: scene references by name or index are fragile. As soon as a
    scene is renamed, moved, or reorganized in the Build Settings, all references
    break and can cause silent errors in production. Scene Registry replaces these
    references with <b>GUIDs</b>, unique identifiers that remain valid regardless
    of what happens to your scenes.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_fontSharedMaterials: []
